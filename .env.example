# Liquid Network - Blockstream Esplora REST API (testnet)
ESPLORA_BASE_URL=https://blockstream.info/liquidtestnet/api

# Express server
PORT=3001
NODE_ENV=development

# SQLite database path
DB_PATH=./compliance/db/compliance.sqlite

# Travel Rule threshold (in satoshis, 1000 sat = default)
TRAVEL_RULE_THRESHOLD_SAT=1000

# ── VASP hot wallet (Liquid testnet) ──────────────────────────────────────────
# Laisser vide → mode DÉMO (txid simulé, pas de diffusion réelle)
# Alimenter via : https://liquidtestnet.com/faucet
# Générer : node -e "const {wallet}=require('./chain'); console.log(wallet.generateWallet())"
VASP_PRIVATE_KEY=
VASP_BLINDING_KEY=

# ── VASP identité ─────────────────────────────────────────────────────────────
VASP_NAME=EuroExchange SA
VASP_LEI=FR-LEI-EUROEXCH-001
PARTNER_VASP_NAME=AbidjanPay SARL
PARTNER_VASP_LEI=CI-LEI-ABIDJANPAY-001

# ── Frais (satoshis) ──────────────────────────────────────────────────────────
DEFAULT_FEE_SAT=500
